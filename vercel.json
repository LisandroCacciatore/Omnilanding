{
  "rewrites": [
    {
      "source": "/app",
      "destination": "https://omnicomrade.vercel.app/login"
    },
    {
      "source": "/signin",
      "destination": "https://omnicomrade.vercel.app/login"
    },
    {
      "source": "/login",
      "destination": "https://omnicomrade.vercel.app/login"
    },
    {
      "source": "/app/:path*",
      "destination": "https://omnicomrade.vercel.app/:path*"
    }
  ]
}
